{
  "manifest_version": 3,
  "name": "Eurognosi Homework Sheet Generator",
  "version": "1.1",
  "description": "Adds a button to each group post on eurognosi-fni.com that generates a printable homework Word document.",
  "browser_specific_settings": {
    "gecko": {
      "id": "homework-sheets@eurognosi-fni.com",
      "strict_min_version": "115.0",
      "update_url": "https://raw.githubusercontent.com/roydestroy/homework-sheets/main/updates.json"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.eurognosi-fni.com/group/*",
        "https://www.eurognosi-fni.com/*/group/*"
      ],
      "js": ["docx-lib.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
